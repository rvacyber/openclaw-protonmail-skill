{
  "name": "openclaw-protonmail-skill",
  "version": "0.1.0",
  "description": "ProtonMail skill for OpenClaw via Proton Mail Bridge",
  "keywords": ["openclaw", "protonmail", "email", "imap", "smtp", "skill"],
  "author": "Jim Staley",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/YOUR-USERNAME/openclaw-protonmail-skill.git"
  },
  "bugs": {
    "url": "https://github.com/YOUR-USERNAME/openclaw-protonmail-skill/issues"
  },
  "homepage": "https://github.com/YOUR-USERNAME/openclaw-protonmail-skill#readme",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "install-skill": "npm run build && ln -sf $(pwd) ~/.openclaw/skills/protonmail"
  },
  "dependencies": {
    "imap": "^0.8.19",
    "nodemailer": "^6.9.0",
    "mailparser": "^3.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/imap": "^0.8.40",
    "@types/nodemailer": "^6.4.15",
    "@types/jest": "^29.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": ["<rootDir>/test"],
    "testMatch": ["**/*.test.ts"],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/**/*.d.ts"
    ]
  }
}
